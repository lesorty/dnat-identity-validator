#!/bin/sh
set -eu

# Bootstrap minimo de PID 1 dentro da microVM de build.
mount -t proc none /proc
mount -t sysfs none /sys
mount -t devtmpfs none /dev 2>/dev/null || true
# Toda observabilidade do guest sai pela serial do Firecracker.
exec >/dev/ttyS0 2>&1

/runner

sync

# Tenta varias estrategias de desligamento porque nem toda combinacao kernel/rootfs reage igual.
poweroff -f || true
reboot -f || true
halt -f || true

if command -v busybox >/dev/null 2>&1; then
    busybox poweroff -f || true
    busybox halt -f || true
    busybox reboot -f || true
fi

if [ -w /proc/sys/kernel/sysrq ]; then
    echo 1 > /proc/sys/kernel/sysrq 2>/dev/null || true
fi

if [ -w /proc/sysrq-trigger ]; then
    echo o > /proc/sysrq-trigger
fi

echo "Guest shutdown command failed; keeping PID 1 alive."
while true; do
    sleep 1
done
