@startuml
title DNAT - Sequencia de Execucao

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Arial
skinparam ArrowColor #2E4057
skinparam ArrowThickness 1.2
skinparam sequence {
  LifeLineBorderColor #486581
  LifeLineBackgroundColor #F7FAFC
  ParticipantBorderColor #2E4057
  ParticipantBackgroundColor #FFFFFF
  ActorBorderColor #2E4057
  ActorBackgroundColor #FFFFFF
}

actor Usuario as U
participant "CVM1\nFrontend + API" as C1
participant "Marketplace" as M
participant "IPFS" as I
participant "CVM2\nExecutor API" as C2
participant "microVM de execucao" as E

U -> C1 : solicita execucao
activate C1
C1 -> M : verifica permissao de acesso
activate M
M --> C1 : acesso autorizado
deactivate M
C1 -> I : baixa dataset + application.ext4 criptografado
activate I
I --> C1 : retorna artefatos
deactivate I
C1 -> C1 : descriptografa artefato\nmonta bundle temporario
C1 -> C2 : POST /execute
activate C2
C2 -> E : sobe microVM sem rede
activate E
E -> E : monta dataset + application.ext4\nexecuta aplicacao
E --> C2 : result.json + stdout.txt + stderr.txt
deactivate E
C2 --> C1 : resposta consolidada
deactivate C2
C1 --> U : exibe resultado final
deactivate C1

@enduml
