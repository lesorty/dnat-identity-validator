@startuml
title DNAT - Sequencia de Execucao

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Arial
skinparam ArrowColor #2E4057
skinparam ArrowThickness 1.2
skinparam sequence {
  LifeLineBorderColor #486581
  LifeLineBackgroundColor #F7FAFC
  ParticipantBorderColor #2E4057
  ParticipantBackgroundColor #FFFFFF
  ActorBorderColor #2E4057
  ActorBackgroundColor #FFFFFF
}

actor Usuario as U
participant "CVM1\nFrontend + API" as C1
participant "Marketplace" as M
participant "IPFS" as I
participant "CVM3\nExecutor API" as C3
participant "microVM de execucao" as E

U -> C1 : 1. solicita execucao
activate C1
C1 -> M : 2. verifica permissao de acesso
activate M
M --> C1 : 3. acesso autorizado
deactivate M
C1 -> I : 4. baixa dataset + application.ext4 criptografado
activate I
I --> C1 : 5. retorna artefatos
deactivate I
C1 -> C1 : 6. descriptografa artefato\nmonta bundle temporario
C1 -> C3 : 7. POST /execute
activate C3
C3 -> E : 8. sobe microVM sem rede
activate E
E -> E : 9. monta dataset + application.ext4\nexecuta aplicacao
E --> C3 : 10. result.json + stdout.txt + stderr.txt
deactivate E
C3 --> C1 : 11. resposta consolidada
deactivate C3
C1 --> U : 12. exibe resultado final
deactivate C1

@enduml
