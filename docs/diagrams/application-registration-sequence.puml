@startuml
title DNAT - Sequencia de Registro da Aplicacao

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Arial
skinparam ArrowColor #2E4057
skinparam ArrowThickness 1.2
skinparam sequence {
  LifeLineBorderColor #486581
  LifeLineBackgroundColor #F7FAFC
  ParticipantBorderColor #2E4057
  ParticipantBackgroundColor #FFFFFF
  ActorBorderColor #2E4057
  ActorBackgroundColor #FFFFFF
}

actor Usuario as U
participant "CVM1\nFrontend + API" as C1
participant "CVM2\nBuilder API" as C2
participant "worker\nefemero" as W
participant "microVM de build" as B
participant "IPFS" as I

U -> C1 : 1. envia aplicacao + manifesto
activate C1
C1 -> C1 : 2. materializa upload\nmonta request bundle
C1 -> C2 : 3. POST /build
activate C2
C2 -> W : 4. cria worker por requisicao
activate W
W -> B : 5. sobe microVM via Firecracker
activate B
B -> B : 6. resolve dependencias\ninstala site-packages\ngera application.ext4
B --> W : 7. application.ext4 + wheelhouse
deactivate B
W -> C2 : 8. persiste apenas .whl validas
deactivate W
C2 --> C1 : 9. application.ext4 + build-result.json
deactivate C2
C1 -> C1 : 10. criptografa application.ext4
C1 -> I : 11. publica blob no IPFS
C1 --> U : 12. confirma registro
deactivate C1

@enduml
