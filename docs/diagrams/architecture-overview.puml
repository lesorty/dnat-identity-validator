@startuml
title DNAT - Visao Geral da Arquitetura

left to right direction

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Arial
skinparam ArrowColor #2E4057
skinparam ArrowThickness 1.2
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam nodesep 70
skinparam ranksep 90
skinparam node {
  BackgroundColor #F7FAFC
  BorderColor #2E4057
  FontColor #1F2933
}
skinparam component {
  BackgroundColor #FFFFFF
  BorderColor #486581
  FontColor #102A43
}
skinparam database {
  BackgroundColor #FFFFFF
  BorderColor #486581
  FontColor #102A43
}
skinparam artifact {
  BackgroundColor #FFFFFF
  BorderColor #486581
  FontColor #102A43
}

actor "Usuario / Browser" as User

node "CVM1\nCliente e camada de acesso" as CVM1 {
  component "dnat-client\nFrontend + API" as CLIENT
  database "IPFS local" as IPFS
  component "Marketplace\ncontrato + criptografia" as MARKET
}

node "CVM2\nBuilder isolado" as CVM2 {
  component "dnat-builder\nAPI de build" as BUILDER
  component "worker efemero" as WORKER
  database "Cache de .whl" as WHEELCACHE
}

node "CVM3\nExecutor isolado" as CVM3 {
  component "dnat-executor\nAPI de execucao" as EXECUTOR
}

node "microVM de build\nFirecracker" as BUILDVM
node "microVM de execucao\nFirecracker" as EXECVM

artifact "application.ext4" as APPART
artifact "dataset + result.json\nstdout/stderr" as EXECART

BUILDVM -[hidden]down- APPART
EXECVM -[hidden]down- EXECART
CVM1 -[hidden]right- CVM2
CVM2 -[hidden]right- CVM3

User -down-> CLIENT : B1 / E1\nupload / consulta /\nexecucao
CLIENT -up-> User : B7 / E6\nresposta final

CLIENT -right-> BUILDER : B2\nbundle\nde build
BUILDER -down-> WORKER : B3\ncria worker\npor requisicao
WORKER -left-> BUILDVM : B4\nbuild-vm.sh
BUILDVM -down-> APPART : B5\ngera\nartefato
BUILDVM -up-> WHEELCACHE : B5a\nreutiliza /\ngera wheels
BUILDER -left-> CLIENT : B6\napplication.ext4 +\nbuild-result.json

CLIENT -down-> IPFS : B7a\npublica blob\ncriptografado

CLIENT -right-> EXECUTOR : E2\nbundle\nde execucao
EXECUTOR -down-> EXECVM : E3\nrun-vm.sh
EXECVM -down-> EXECART : E4\ngrava\nsaida
EXECUTOR -left-> CLIENT : E5\nresult.json +\nstdout/stderr

note right of CVM2
Persistente:
- cache de .whl

Efemero:
- worker
- discos temporarios
- microVM de build
end note

note right of CVM3
Persistente:
- runtime base

Efemero:
- bundle de execucao
- microVM executora
- discos de entrada/saida
end note

@enduml
