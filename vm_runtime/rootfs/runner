#!/usr/bin/env python3

import subprocess
import sys
import pathlib
import json

dataset = pathlib.Path("/data/dataset.csv")
script = pathlib.Path("/data/application.py")
result = pathlib.Path("/data/result.json")

cmd = [
    sys.executable,
    str(script),
    "--dataset",
    str(dataset),
    "--output",
    str(result)
]

proc = subprocess.run(cmd, capture_output=True, text=True)

metadata = {
    "returncode": proc.returncode,
    "stdout": proc.stdout,
    "stderr": proc.stderr
}

print(json.dumps(metadata))

sys.exit(proc.returncode)