#!/usr/bin/env python3

import subprocess, sys, os, json, time, shutil

def write_serial(msg):
    try:
        with open('/dev/ttyS0', 'w') as f:
            f.write(msg + '\n')
            f.flush()
    except:
        pass

WORKDIR = '/tmp/exec'
OUTPUT_DIR = '/mnt/output'

os.makedirs(WORKDIR, exist_ok=True)
os.chdir(WORKDIR)

# Wait for data disks
bundle_path = None
output_mount = None
for i in range(30):
    for disk in ['/dev/vdb', '/dev/vdc', '/dev/vdd', '/dev/vde']:
        if os.path.exists(disk):
            mount_dir = f"/mnt/{os.path.basename(disk)}"
            os.makedirs(mount_dir, exist_ok=True)
            subprocess.run(['mount', disk, mount_dir], check=False)

            candidate_bundle = os.path.join(mount_dir, 'bundle.tar.gz')
            if os.path.isfile(candidate_bundle):
                bundle_path = candidate_bundle
            else:
                output_mount = mount_dir
    if bundle_path and output_mount:
        break
    time.sleep(1)

if output_mount:
    OUTPUT_DIR = output_mount

try:
    write_serial("[START]")

    if not bundle_path or not os.path.isfile(bundle_path):
        raise Exception("Bundle disk not found")

    shutil.copyfile(bundle_path, 'bundle.tar.gz')
    
    # Extract
    result = subprocess.run(['tar', '-xzf', 'bundle.tar.gz'], capture_output=True, text=True)
    if result.returncode != 0:
        raise Exception(result.stderr)
    
    # Execute
    result = subprocess.run(
        ['bash', 'workspace/run.sh'],
        capture_output=True, text=True, timeout=600
    )
    
    output = {
        "returncode": result.returncode,
        "stdout": result.stdout,
        "stderr": result.stderr
    }

except Exception as e:
    output = {"returncode": 1, "stdout": "", "stderr": str(e)}
except subprocess.TimeoutExpired:
    output = {"returncode": 124, "stdout": "", "stderr": "timeout"}

finally:
    if os.path.ismount(OUTPUT_DIR):
        try:
            with open(f'{OUTPUT_DIR}/result.json', 'w') as f:
                json.dump(output, f)
        except:
            print(json.dumps(output))
    else:
        print(json.dumps(output))
    
    write_serial("EXECUTION_COMPLETE")
    subprocess.run(['sync'], check=False)
    subprocess.run(['poweroff', '-f'], check=False)

sys.exit(output.get("returncode", 1))
