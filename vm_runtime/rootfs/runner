#!/usr/bin/env python3

import json
import os
import shutil
import subprocess
import sys
import time
from pathlib import Path

WORKDIR = '/tmp/exec'
INPUT_DISKS = ['/dev/vdb', '/dev/vdc', '/dev/vdd', '/dev/vde']
OUTPUT_MARKER = 'dnat-output.marker'
APPLICATION_MARKER = 'dnat-application.marker'
RESULT_PATH = 'result.json'
STDOUT_PATH = 'stdout.txt'
STDERR_PATH = 'stderr.txt'
EXECUTION_COMPLETE_MARKER = 'EXECUTION_COMPLETE'


def safe_mount(device: str, mount_dir: str) -> bool:
    result = subprocess.run(
        ['mount', device, mount_dir],
        check=False,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    return result.returncode == 0


def discover_mounts() -> tuple[str | None, str | None, str | None]:
    mounted: dict[str, str] = {}

    for _ in range(30):
        bundle_path = None
        output_dir = None
        application_dir = None

        for disk in INPUT_DISKS:
            if not os.path.exists(disk):
                continue

            mount_dir = mounted.get(disk)
            if mount_dir is None:
                mount_dir = f"/mnt/{os.path.basename(disk)}"
                os.makedirs(mount_dir, exist_ok=True)
                if not safe_mount(disk, mount_dir):
                    continue
                mounted[disk] = mount_dir

            candidate_bundle = os.path.join(mount_dir, 'bundle.tar.gz')
            if bundle_path is None and os.path.isfile(candidate_bundle):
                bundle_path = candidate_bundle

            if output_dir is None and os.path.isfile(os.path.join(mount_dir, OUTPUT_MARKER)):
                output_dir = mount_dir

            if application_dir is None and os.path.isfile(os.path.join(mount_dir, APPLICATION_MARKER)):
                application_dir = mount_dir

        if bundle_path and output_dir:
            return bundle_path, output_dir, application_dir

        time.sleep(1)

    return None, None, None


def persist_output(output_dir: str | None, output: dict) -> None:
    if not output_dir:
        return

    output_path = Path(output_dir)
    temp_result = output_path / f"{RESULT_PATH}.tmp"
    temp_result.write_text(json.dumps(output), encoding='utf-8')
    temp_result.replace(output_path / RESULT_PATH)

    (output_path / STDOUT_PATH).write_text(output.get('stdout', '') or '', encoding='utf-8')
    (output_path / STDERR_PATH).write_text(output.get('stderr', '') or '', encoding='utf-8')
    subprocess.run(['sync'], check=False)


def write_serial(message: str) -> None:
    try:
        with open('/dev/ttyS0', 'a', encoding='utf-8', errors='ignore') as serial:
            serial.write(f"{message}\n")
            serial.flush()
    except OSError:
        pass

os.makedirs(WORKDIR, exist_ok=True)
os.chdir(WORKDIR)

bundle_path, output_dir, application_dir = discover_mounts()

try:
    if not bundle_path or not os.path.isfile(bundle_path):
        raise Exception("Bundle disk not found")
    if not output_dir:
        raise Exception("Output disk not found")

    app_symlink = Path('/mnt/dnat-app')
    if application_dir:
        try:
            if app_symlink.exists() or app_symlink.is_symlink():
                app_symlink.unlink()
        except OSError:
            pass
        os.symlink(application_dir, app_symlink)

    shutil.copyfile(bundle_path, 'bundle.tar.gz')
    
    # Extract
    result = subprocess.run(['tar', '-xzf', 'bundle.tar.gz'], capture_output=True, text=True)
    if result.returncode != 0:
        raise Exception(result.stderr)
    
    # Execute
    result = subprocess.run(
        ['bash', 'workspace/run.sh'],
        capture_output=True, text=True, timeout=600
    )
    
    output = {
        "returncode": result.returncode,
        "stdout": result.stdout,
        "stderr": result.stderr
    }

except subprocess.TimeoutExpired:
    output = {"returncode": 124, "stdout": "", "stderr": "timeout"}
except Exception as e:
    output = {"returncode": 1, "stdout": "", "stderr": str(e)}

finally:
    persist_output(output_dir, output)
    write_serial(EXECUTION_COMPLETE_MARKER)
    sys.exit(0)
